# ============================================================
# HawkWatch Server — Environment Variables
# Copy this file to .env and fill in the real values.
# Never commit .env to source control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────
# Primary key used in code (MONGO_URI kept as alias for backwards compat)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hawkwatch?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hawkwatch?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Access token — short-lived (15 min). Use a long random string.
JWT_ACCESS_SECRET=replace_with_a_64_char_random_hex_string
# Kept for backwards compatibility (JWT_ACCESS_SECRET takes precedence)
JWT_SECRET=replace_with_a_64_char_random_hex_string

# Refresh token — 7 days
JWT_REFRESH_SECRET=replace_with_a_different_64_char_random_hex_string

# ── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=hawkwatch-proctoring-media

# ── Email (nodemailer / Gmail App Password) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@hawkwatch.app

# ── AI Proctoring Microservice ───────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_ai_service_key

# ── Rate Limiting ─────────────────────────────────────────────
# windowMs = 15 min (in ms), max = requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CV / AI Thresholds ────────────────────────────────────────
FACE_CONFIDENCE_THRESHOLD=0.7
DEEPFAKE_SCORE_THRESHOLD=0.6
BEHAVIORAL_ANOMALY_THRESHOLD=0.75
REKOGNITION_SIMILARITY_THRESHOLD=70
